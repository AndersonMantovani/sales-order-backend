{
  "compilerOptions": {
    "target": "es2024",
    "module": "node20",
    "moduleResolution": "node16",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@cap-js"
    ],
    "paths": {
      "*": ["./*"],
      "@models/*": ["./@cds-models/*/index.ts"]
    },
    "rootDir": "./"
  },
  "include": ["srv"],
  "exclude": ["node_modules"]
}